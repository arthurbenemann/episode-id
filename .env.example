# Path on the host containing the MKVs you want to identify. Mounted into the
# container at /media/input.
MEDIA_INPUT=./media/input

# Path on the host where your Jellyfin TV library lives. Mounted at /media/tv.
# Renamed files are placed under this root in Jellyfin-compatible layout.
LIBRARY_ROOT=./media/tv

# How many seconds into each MKV to start sampling dialogue. Skipping the
# first few minutes avoids cold opens, recaps, and title sequences which
# vary across episodes and would weaken the match.
SAMPLE_START_SECONDS=180

# How many subtitle lines to feed into the fuzzy matcher per file.
SAMPLE_LINE_COUNT=40

# Matches scoring below this confidence (0-100) are flagged for review.
MIN_CONFIDENCE=70

# Output naming. See https://jellyfin.org/docs/general/server/media/shows/
RENAME_TEMPLATE={series_title} - S{season:02}E{episode:02} - {episode_title}.{ext}
SERIES_FOLDER_TEMPLATE={series_title} ({year}) [tvdbid-{tvdb_id}]
INCLUDE_PROVIDER_ID=true

# SQLite transcript cache. Downloads from OpenSubtitles count against a
# small daily quota, so fetched transcripts are cached here and reused.
DATABASE_URL=sqlite:///./data/episode-id.db

# Required for --provider opensubtitles. Free key from
# https://www.opensubtitles.com/consumers (no account login needed).
# OPENSUBTITLES_API_KEY=

# Reserved for future milestones (TVDB show search).
# TVDB_API_KEY=
